# -------------------------
# Environment / secrets
# -------------------------
.env
.env.*
!.env.example

# Secrets / keys (general)
*.keystore
*.jks
*.p12
*.pem
*.key
*.mobileprovision
*.cer
*.crt
*.der

# -------------------------
# Node / Backend (repo-wide)
# -------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Backend runtime generated
backend/uploads/

# Prisma local artifacts (keep schema + migrations tracked)
backend/node_modules/.prisma/
backend/prisma/.cache/
backend/prisma/*.db
backend/prisma/*.db-journal

# -------------------------
# Flutter / Mobile (mobile/)
# -------------------------
# Dart/Flutter tooling
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.packages
mobile/build/
mobile/coverage/

# (Recommended) commit pubspec.lock for apps.
# If you really want to ignore it, keep this line.
# mobile/pubspec.lock

# Android
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/**/build/
mobile/android/captures/
mobile/android/key.properties
mobile/android/.idea/

# iOS / CocoaPods / Xcode
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/ephemeral/
mobile/ios/Podfile.lock
mobile/ios/Runner.xcworkspace/
mobile/ios/Runner.xcodeproj/xcuserdata/
mobile/ios/Runner/DerivedData/
DerivedData/

# macOS / Xcode (if you have macos/)
mobile/macos/Pods/
mobile/macos/Flutter/ephemeral/
mobile/macos/Podfile.lock

# Firebase config (ONLY ignore if you do NOT want to commit them)
# mobile/android/app/google-services.json
# mobile/ios/Runner/GoogleService-Info.plist

# -------------------------
# OS / IDE
# -------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml

# -------------------------
# Optional: PDFs (only if you truly want to ignore all pdf assets)
# -------------------------
# If PDFs in assets should be committed, REMOVE these lines.
mobile/assets/*.pdf
mobile/**/assets/**/*.pdf