generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  firebaseUid  String   @unique
  email        String?  @unique
  phone        String?
  name         String?
  role         String   @default("Resident")
  ward         String?
  fcmToken     String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // schedules created by ward admin
  schedules        WaterSchedule[] @relation("UserSchedules")

  savedLocations   SavedLocation[]
  residentBookings Booking[]       @relation("ResidentBookings")
  vendorBookings   Booking[]       @relation("VendorBookings")
  issues           Issue[]

  // Inverse relation for TankerRoute.vendor
  tankerRoutes     TankerRoute[]

  @@map("users")
}

model WaterSchedule {
  id              Int      @id @default(autoincrement())
  ward            String
  affectedAreas   String?        // optional (recommended)
  supplyDate      DateTime
  startTime       String
  endTime         String
  notifyResidents Boolean @default(false)

  createdBy       Int
  createdAt       DateTime @default(now())

  admin           User     @relation("UserSchedules", fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("water_schedules")
}

model Notification {
  id        Int      @id @default(autoincrement())
  ward      String
  title     String
  message   String
  createdAt DateTime @default(now())

  @@map("notifications")
}

model SavedLocation {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  address   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_locations")
}

model Booking {
  id         Int      @id @default(autoincrement())
  residentId Int
  vendorId   Int?
  ward       String?
  liters     Int?
  price      Float?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  // Link to tanker slot (optional)
  slotId     Int?
  slot       TankerSlot? @relation(fields: [slotId], references: [id])

  resident   User     @relation("ResidentBookings", fields: [residentId], references: [id], onDelete: Cascade)
  vendor     User?    @relation("VendorBookings", fields: [vendorId], references: [id])

  @@map("bookings")
}

model TankerRoute {
  id          Int          @id @default(autoincrement())
  vendorId    Int
  vendor      User         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  ward        String?
  name        String
  description String?

  slots       TankerSlot[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tanker_routes")
}

model TankerSlot {
  id             Int          @id @default(autoincrement())
  routeId        Int
  route          TankerRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  date           DateTime
  startTime      DateTime
  endTime        DateTime

  capacityLiters Int
  bookedLiters   Int          @default(0)
  status         String       @default("OPEN") // OPEN | CLOSED | CANCELLED

  bookings       Booking[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tanker_slots")
}

model Issue {
  id          Int      @id @default(autoincrement())
  residentId  Int
  ward        String?
  title       String
  description String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resident    User     @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@map("issues")
}