generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RESIDENT
  VENDOR
  WARD_ADMIN
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum NotificationType {
  GENERAL
  SCHEDULE
  BOOKING
  ALERT
}

model Ward {
  id        Int      @id @default(autoincrement()) @map("ward_id")
  wardName  String   @map("ward_name")
  location  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  schedules Schedule[]
  routes    Route[]

  @@map("wards")
}

model User {
  id           Int      @id @default(autoincrement()) @map("user_id")
  firebaseUid  String   @unique @map("firebase_uid")

  name         String?
  email        String?  @unique
  phoneNumber  String?  @map("phone_number")
  role         UserRole @default(RESIDENT)

  passwordHash String?  @map("password_hash")


  // WARD_ADMIN => must be NULL
  wardId       Int?     @map("ward_id")
  ward         Ward?    @relation(fields: [wardId], references: [id], onDelete: SetNull)

  profileImageUrl String? @map("profile_image_url")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // schedules posted by this user (WARD_ADMIN)
  schedulesCreated Schedule[] @relation("ScheduleCreator")

  fcmTokens       FcmToken[]
  vendorProfile   Vendor?

  bookings        Booking[]
  complaints      Complaint[]

  sentNotifications      Notification[]          @relation("NotificationSender")
  notificationRecipients NotificationRecipient[] @relation("NotificationRecipientUser")

  @@map("users")
}

model FcmToken {
  id         Int      @id @default(autoincrement()) @map("token_id")
  userId     Int      @map("user_id")
  token      String   @unique
  deviceInfo String?  @map("device_info")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries NotificationRecipient[] @relation("RecipientToken")

  @@map("fcm_tokens")
}

model Vendor {
  id          Int     @id @default(autoincrement()) @map("vendor_id")
  userId      Int     @unique @map("user_id")
  companyName String? @map("company_name")
  phone       String?
  address     String? @map("address")
  tankerCount Int     @default(0) @map("tanker_count")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routes      Route[]

  @@map("vendors")
}

model Schedule {
  id           Int      @id @default(autoincrement()) @map("schedule_id")
  wardId       Int      @map("ward_id")

  // REQUIRED: who posted the schedule (WARD_ADMIN user_id)
  createdById  Int      @map("created_by")
  createdBy    User     @relation("ScheduleCreator", fields: [createdById], references: [id], onDelete: Restrict)

  scheduleDate DateTime @map("schedule_date")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ward         Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)

  @@index([wardId])
  @@index([createdById])
  @@map("schedules")
}

model Route {
  id        Int      @id @default(autoincrement()) @map("route_id")
  vendorId  Int      @map("vendor_id")
  wardId    Int      @map("ward_id")

  routeDate DateTime @map("route_date")
  location  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  ward      Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)

  slots     Slot[]

  @@index([vendorId])
  @@index([wardId])
  @@map("routes")
}

model Slot {
  id          Int      @id @default(autoincrement()) @map("slot_id")
  routeId     Int      @map("route_id")

  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")

  capacity    Int
  bookedCount Int      @default(0) @map("booked_count")
  price Int? @map("price")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  route       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([routeId])
  @@map("slots")
}

model Booking {
  id        Int           @id @default(autoincrement()) @map("booking_id")
  userId    Int           @map("user_id")
  slotId    Int           @map("slot_id")
  status    BookingStatus @default(PENDING)

  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      Slot          @relation(fields: [slotId], references: [id], onDelete: Cascade)

  payment        Payment?
  statusHistory  StatusHistory[]
  complaints     Complaint[]

  @@index([userId])
  @@index([slotId])
  @@map("bookings")
}

model Payment {
  id            Int           @id @default(autoincrement()) @map("payment_id")
  bookingId     Int           @unique @map("booking_id")

  method        String
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)

  paidAt        DateTime?     @map("paid_at")
  transactionId String?       @map("transaction_id")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model StatusHistory {
  id        Int           @id @default(autoincrement()) @map("history_id")
  bookingId Int           @map("booking_id")

  oldStatus BookingStatus @map("old_status")
  newStatus BookingStatus @map("new_status")
  changedAt DateTime      @default(now()) @map("changed_at")

  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("status_history")
}

model Complaint {
  id        Int             @id @default(autoincrement()) @map("complaint_id")
  userId    Int             @map("user_id")
  bookingId Int             @map("booking_id")

  message   String
  status    ComplaintStatus @default(OPEN)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  photos    ComplaintPhoto[]

  @@index([userId])
  @@index([bookingId])
  @@map("complaints")
}

model ComplaintPhoto {
  id          Int       @id @default(autoincrement()) @map("photo_id")
  complaintId Int       @map("complaint_id")
  photoUrl    String    @map("photo_url")

  createdAt   DateTime  @default(now()) @map("created_at")

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_photos")
}

model Notification {
  id         Int              @id @default(autoincrement()) @map("notification_id")
  senderId   Int              @map("sender_id")
  senderRole UserRole         @map("sender_role")

  title      String
  message    String
  type       NotificationType @default(GENERAL)

  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  sender     User             @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipients NotificationRecipient[]

  @@index([senderId])
  @@map("notifications")
}

model NotificationRecipient {
  notificationId Int       @map("notification_id")
  recipientId    Int       @map("recipient_id")
  userId         Int       @map("user_id")

  isRead         Boolean   @default(false) @map("is_read")
  deliveredAt    DateTime? @map("delivered_at")

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  token          FcmToken      @relation("RecipientToken", fields: [recipientId], references: [id], onDelete: Cascade)
  user           User          @relation("NotificationRecipientUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, recipientId])
  @@index([userId])
  @@map("notification_recipients")
}